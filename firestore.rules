rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isBootstrapSuperAdmin() {
      return signedIn()
        && request.auth.token.email.lower() == "ayushvashist077@gmail.com";
    }

    function configExists() {
      return exists(/databases/$(database)/documents/config/authorized_users);
    }

    function configDoc() {
      return get(/databases/$(database)/documents/config/authorized_users);
    }

    function userExists() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isConfiguredSuperAdmin() {
      return signedIn()
        && configExists()
        && configDoc().data.superAdmin.hasAny([request.auth.token.email.lower()]);
    }

    function isSuperAdmin() {
      return isBootstrapSuperAdmin() || isConfiguredSuperAdmin();
    }

    function isApprovedUser() {
      return signedIn()
        && userExists()
        && currentUserDoc().data.status == "approved"
        && currentUserDoc().data.emailVerified == true;
    }

    function isApprovedCR() {
      return isApprovedUser()
        && configExists()
        && configDoc().data.crEmails.hasAny([currentUserDoc().data.email]);
    }

    function validUserDoc(data) {
      return data.keys().hasOnly([
          "uid",
          "name",
          "email",
          "status",
          "emailVerified",
          "registeredAt",
          "verifiedAt",
          "approvedAt",
          "approvedBy",
        ])
        && data.uid is string
        && data.name is string
        && data.email is string
        && data.status is string
        && data.emailVerified is bool
        && data.registeredAt is timestamp
        && (data.verifiedAt == null || data.verifiedAt is timestamp)
        && (data.approvedAt == null || data.approvedAt is timestamp)
        && (data.approvedBy == null || data.approvedBy is string);
    }

    function validNewUserDoc(uid) {
      return validUserDoc(request.resource.data)
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email.lower()
        && request.resource.data.status == "pending"
        && request.resource.data.emailVerified == false
        && request.resource.data.verifiedAt == null
        && request.resource.data.approvedAt == null
        && request.resource.data.approvedBy == null;
    }

    function validSelfVerificationUpdate(uid) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return request.auth.uid == uid
        && validUserDoc(request.resource.data)
        && changed.hasOnly(["emailVerified", "verifiedAt"])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.name == resource.data.name
        && request.resource.data.email == resource.data.email
        && request.resource.data.status == resource.data.status
        && request.resource.data.registeredAt == resource.data.registeredAt
        && request.resource.data.approvedAt == resource.data.approvedAt
        && request.resource.data.approvedBy == resource.data.approvedBy
        && resource.data.emailVerified == false
        && request.resource.data.emailVerified == true
        && request.resource.data.verifiedAt is timestamp;
    }

    function validAdminUserUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return validUserDoc(request.resource.data)
        && changed.hasOnly([
          "status",
          "emailVerified",
          "verifiedAt",
          "approvedAt",
          "approvedBy",
        ])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.name == resource.data.name
        && request.resource.data.email == resource.data.email
        && request.resource.data.registeredAt == resource.data.registeredAt
        && (
          request.resource.data.status == "pending"
          || request.resource.data.status == "approved"
          || request.resource.data.status == "rejected"
        )
        && (
          request.resource.data.emailVerified == resource.data.emailVerified
          || request.resource.data.emailVerified == true
        )
        && (
          request.resource.data.emailVerified == false
          || request.resource.data.verifiedAt is timestamp
        );
    }

    function validConfigDoc(data) {
      return data.keys().hasOnly(["crEmails", "superAdmin"])
        && data.crEmails is list
        && data.superAdmin is list;
    }

    function validAssignmentDoc(data) {
      return data.keys().hasAll([
          "subject",
          "title",
          "description",
          "deadline",
          "uploadedDate",
          "status",
          "links",
        ])
        && data.keys().hasOnly([
          "subject",
          "title",
          "description",
          "deadline",
          "uploadedDate",
          "status",
          "links",
          "attachments",
        ])
        && data.subject is string
        && data.subject.size() > 0
        && data.subject.size() <= 200
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 200
        && data.description is string
        && data.description.size() > 0
        && data.description.size() <= 5000
        && data.deadline is timestamp
        && data.uploadedDate is timestamp
        && (data.status == "Pending" || data.status == "Completed")
        && data.links is list
        && (!data.keys().hasAny(["attachments"]) || data.attachments is list);
    }

    match /config/authorized_users {
      allow get: if isApprovedUser() || isSuperAdmin();
      allow create: if isBootstrapSuperAdmin()
        && !configExists()
        && validConfigDoc(request.resource.data);
      allow update: if isSuperAdmin() && validConfigDoc(request.resource.data);
      allow delete: if false;
    }

    match /users/{uid} {
      allow create: if signedIn()
        && !exists(/databases/$(database)/documents/users/$(uid))
        && validNewUserDoc(uid);

      allow get: if (signedIn() && request.auth.uid == uid) || isSuperAdmin();
      allow list: if isSuperAdmin();

      allow update: if (signedIn() && request.auth.uid == uid && validSelfVerificationUpdate(uid))
        || (isSuperAdmin() && validAdminUserUpdate());

      allow delete: if isSuperAdmin();
    }

    match /assignments/{assignmentId} {
      allow get, list: if true;
      allow create: if (isApprovedCR() || isSuperAdmin())
        && validAssignmentDoc(request.resource.data);
      allow update: if (isApprovedCR() || isSuperAdmin())
        && validAssignmentDoc(request.resource.data)
        && request.resource.data.uploadedDate == resource.data.uploadedDate;
      allow delete: if isApprovedCR() || isSuperAdmin();
    }

    match /userProgress/{uid}/assignments/{assignmentId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
